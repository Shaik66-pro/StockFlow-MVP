from fastapi import FastAPI, Depends, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from sqlalchemy.orm import Session
from passlib.context import CryptContext

import models
import schemas
from database import engine, get_db

app = FastAPI(
    title="StockFlow MVP API",
    version="0.1.0"
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=[
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "https://stock-flow-mvp.vercel.app",
        "https://www.stock-flow-mvp.vercel.app",
    ],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

models.Base.metadata.create_all(bind=engine)

pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")


@app.get("/")
def home():
    return {"message": "StockFlow MVP API running"}


@app.post("/signup")
def signup(data: schemas.SignupRequest, db: Session = Depends(get_db)):
    existing_user = db.query(models.User).filter(models.User.email == data.email).first()

    if existing_user:
        raise HTTPException(status_code=400, detail="Email already registered")

    organization = models.Organization(name=data.organization_name)
    db.add(organization)
    db.commit()
    db.refresh(organization)

    hashed_password = pwd_context.hash(data.password)

    user = models.User(
        email=data.email,
        password=hashed_password,
        organization_id=organization.id
    )

    db.add(user)
    db.commit()
    db.refresh(user)

    return {
        "message": "Signup successful",
        "user_id": user.id,
        "organization_id": organization.id
    }


@app.post("/login")
def login(data: schemas.LoginRequest, db: Session = Depends(get_db)):
    user = db.query(models.User).filter(models.User.email == data.email).first()

    if not user:
        raise HTTPException(status_code=401, detail="Invalid email or password")

    if not pwd_context.verify(data.password, user.password):
        raise HTTPException(status_code=401, detail="Invalid email or password")

    return {
        "message": "Login successful",
        "user_id": user.id,
        "organization_id": user.organization_id
    }
    
    
@app.post("/products")
def create_product(product: schemas.ProductCreate, organization_id: int, db: Session = Depends(get_db)):
    existing_product = db.query(models.Product).filter(
        models.Product.organization_id == organization_id,
        models.Product.sku == product.sku
    ).first()

    if existing_product:
        raise HTTPException(status_code=400, detail="SKU already exists in this organization")

    new_product = models.Product(
        organization_id=organization_id,
        name=product.name,
        sku=product.sku,
        description=product.description,
        quantity=product.quantity,
        cost_price=product.cost_price,
        selling_price=product.selling_price,
        low_stock_threshold=product.low_stock_threshold
    )

    db.add(new_product)
    db.commit()
    db.refresh(new_product)

    return new_product


@app.get("/products")
def get_products(organization_id: int, db: Session = Depends(get_db)):
    return db.query(models.Product).filter(
        models.Product.organization_id == organization_id
    ).all()


@app.put("/products/{product_id}")
def update_product(product_id: int, product: schemas.ProductUpdate, organization_id: int, db: Session = Depends(get_db)):
    existing_product = db.query(models.Product).filter(
        models.Product.id == product_id,
        models.Product.organization_id == organization_id
    ).first()

    if not existing_product:
        raise HTTPException(status_code=404, detail="Product not found")

    update_data = product.dict(exclude_unset=True)

    for key, value in update_data.items():
        setattr(existing_product, key, value)

    db.commit()
    db.refresh(existing_product)

    return existing_product


@app.delete("/products/{product_id}")
def delete_product(product_id: int, organization_id: int, db: Session = Depends(get_db)):
    product = db.query(models.Product).filter(
        models.Product.id == product_id,
        models.Product.organization_id == organization_id
    ).first()

    if not product:
        raise HTTPException(status_code=404, detail="Product not found")

    db.delete(product)
    db.commit()

    return {"message": "Product deleted successfully"}

@app.get("/dashboard")
def dashboard(organization_id: int, db: Session = Depends(get_db)):
    products = db.query(models.Product).filter(
        models.Product.organization_id == organization_id
    ).all()

    organization = db.query(models.Organization).filter(
        models.Organization.id == organization_id
    ).first()

    default_threshold = organization.default_low_stock_threshold if organization else 5

    total_products = len(products)
    total_quantity = sum(product.quantity for product in products)

    low_stock_items = []

    for product in products:
        threshold = product.low_stock_threshold if product.low_stock_threshold is not None else default_threshold

        if product.quantity <= threshold:
            low_stock_items.append({
                "id": product.id,
                "name": product.name,
                "sku": product.sku,
                "quantity": product.quantity,
                "low_stock_threshold": threshold
            })

    return {
        "total_products": total_products,
        "total_quantity": total_quantity,
        "low_stock_items": low_stock_items
    }
